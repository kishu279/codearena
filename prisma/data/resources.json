  {
    "id": "res_ml_iiitd_classification_snippet",
    "title": "Dutch National Flag – Solution",
    "type": "CODE_SNIPPET",
    "url": null,
    "content": "```python\ndef sortColors(nums):\n    low, mid, high = 0, 0, len(nums) - 1\n    while mid <= high:\n        if nums[mid] == 0:\n            nums[low], nums[mid] = nums[mid], nums[low]\n            low += 1\n            mid += 1\n        elif nums[mid] == 1:\n            mid += 1\n        else:\n            nums[mid], nums[high] = nums[high], nums[mid]\n            high -= 1\n```",
    "labId": "lab_ml_iiitd",
    "assignmentId": "assign_ml_classification",
    "uploadedById": "user_inst3_instructor_1",
    "isPublic": false
